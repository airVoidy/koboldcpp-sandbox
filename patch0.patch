-.slot-thread-body { padding-left:8px; }
-.slot-thread-body.open { display:block; }
-.tmsg { display:flex; align-items:flex-start; gap:6px; padding:3px 0; font-size:11px; }
-.tmsg-avatar { width:18px; height:18px; border-radius:50%; background:var(--surface2); display:flex; align-items:center; justify-content:center; font-size:9px; font-weight:600; color:var(--accent); flex-shrink:0; }
-.tmsg-who { font-size:10px; font-weight:600; color:var(--text-dim); min-width:40px; }
-.tmsg-text { flex:1; white-space:pre-wrap; word-break:break-word; }
-
-/* Slot time */
-.slot-time { font-size:9px; color:var(--text-dim); margin-left:auto; }
-
-/* Table */
-.v3-table { width:100%; border-collapse:collapse; font-size:10px; }
-.v3-table th, .v3-table td { padding:2px 6px; border:1px solid var(--border); text-align:left; }
-.v3-table th { background:var(--surface2); color:var(--text-dim); font-weight:600; }
-
-/* Schema-render mode — each slot in labeled frame */
-.schema-card { margin:6px 0; border:1px dashed var(--border); border-radius:4px; background:var(--surface); }
-.schema-card .node-hdr { border-bottom:1px solid var(--border); }
-.schema-card .schema-body { padding:4px; }
-.schema-card .schema-body.collapsed { display:none; }
-.slot-frame { position:relative; margin:3px 2px; border:1px solid var(--border); border-radius:3px; min-height:18px; }
-.slot-frame:hover { border-color:var(--accent); }
-.slot-frame-label { position:absolute; top:-8px; left:6px; font-size:8px; padding:0 3px; background:var(--surface); color:var(--accent2); font-weight:600; letter-spacing:.5px; z-index:1; }
-.slot-frame-content { padding:4px 6px; }
-.slot-frame-content.sf-collapsed { display:none; }
-.slot-frame-empty { padding:4px 6px; font-size:10px; color:var(--text-dim); font-style:italic; }
-.slot-frame-toggle { position:absolute; top:-8px; right:6px; font-size:8px; padding:0 3px; background:var(--surface); color:var(--text-dim); cursor:pointer; z-index:1; }
-.slot-frame-toggle:hover { color:var(--accent); }
-
-/* Schema inspect overlay */
-.schema-inspect { position:relative; }
-.schema-inspect .slot-frame-label { color:var(--green); background:var(--surface2); }
-
-/* Views editor */
-.ve-section { margin-bottom:10px; }
-.ve-section-hdr { font-size:10px; color:var(--accent); font-weight:600; display:flex; align-items:center; gap:4px; padding:2px 0; border-bottom:1px solid var(--border); margin-bottom:4px; }
-.ve-section-hdr button { font-size:9px; padding:0 4px; margin-left:auto; }
-.ve-item { padding:4px; background:var(--surface2); border-radius:3px; margin-bottom:4px; }
-.ve-item-hdr { display:flex; align-items:center; gap:4px; font-size:11px; font-weight:600; cursor:pointer; }
-.ve-item-hdr:hover { color:var(--accent); }
-.ve-item-body { display:none; padding:4px 0 0 8px; }
-.ve-item-body.open { display:block; }
-.ve-row { display:flex; align-items:center; gap:3px; margin:2px 0; font-size:10px; }
-.ve-row label { color:var(--text-dim); min-width:50px; }
-.ve-row input, .ve-row select { font-size:10px; padding:1px 3px; flex:1; min-width:0; }
-.ve-row .ve-del { color:var(--red); cursor:pointer; padding:0 3px; font-size:11px; }
-.ve-row .ve-del:hover { color:#fff; }
-.ve-slot-row { display:flex; align-items:center; gap:3px; padding:2px 0; font-size:10px; border-bottom:1px solid var(--surface); }
-.ve-slot-row:last-child { border-bottom:none; }
-.ve-field-row { display:flex; align-items:center; gap:3px; font-size:9px; padding:1px 0; }
-.ve-field-row input { font-size:9px; padding:1px 2px; }
-.ve-mapping { width:100%; font-family:monospace; font-size:9px; background:var(--surface); color:var(--text); border:1px solid var(--border); border-radius:3px; padding:3px 5px; resize:vertical; line-height:1.3; }
-.ve-mapping:focus { border-color:var(--accent); outline:none; }
-.skel-table { width:100%; border-collapse:collapse; }
-.skel-table td { border:1px solid var(--border); padding:4px 6px; vertical-align:top; font-size:9px; }
-.skel-label { color:var(--accent2); font-size:8px; font-weight:600; margin-bottom:2px; }
-.skel-value { color:var(--text); font-size:10px; min-height:14px; word-break:break-word; }
-.skel-table td.skel-empty { color:var(--text-dim); font-style:italic; opacity:.5; }
-.skel-table td.skel-highlight { border-color:var(--accent); background:var(--surface2); }
-.skel-row-controls { display:flex; gap:2px; align-items:center; margin:2px 0; }
-[data-editor-tab].active { color:var(--accent); border-bottom:2px solid var(--accent); }
-
-/* View editor modal columns */
-.ve-col-hdr { font-size:12px; font-weight:600; color:var(--accent); margin-bottom:6px; }
-
-/* Event log */
-.event-item { font-size:10px; padding:2px 0; border-bottom:1px solid var(--surface2); }
-.event-ts { color:var(--text-dim); }
-.event-type { font-weight:600; }
-.event-type.done { color:var(--green); }
-.event-type.failed { color:var(--red); }
-
-/* Tabs */
-.tab-bar { display:flex; gap:2px; padding:2px 8px; border-bottom:1px solid var(--border); flex-shrink:0; }
-.tab-btn { padding:3px 8px; font-size:11px; border:none; background:transparent; color:var(--text-dim); border-bottom:2px solid transparent; }
-.tab-btn.active { color:var(--accent); border-bottom-color:var(--accent); }
-
-/* Top-level pages */
-.page-tabs { display:flex; gap:0; padding:0 12px; border-bottom:1px solid var(--border); background:var(--surface); flex-shrink:0; }
-.page-tab { padding:6px 16px; font-size:12px; font-weight:600; border:none; background:transparent; color:var(--text-dim); border-bottom:2px solid transparent; cursor:pointer; }
-.page-tab:hover { color:var(--text); }
-.page-tab.active { color:var(--accent); border-bottom-color:var(--accent); }
-.page { display:none; flex:1; min-height:0; }
-.page.active { display:flex; }
-
-/* JSON inspector */
-.json-inspector { position:fixed; z-index:90; background:var(--bg); border:1px solid var(--accent); border-radius:4px; padding:0; max-width:500px; max-height:400px; box-shadow:0 4px 16px rgba(0,0,0,.5); }
-.json-inspector-hdr { display:flex; align-items:center; padding:4px 8px; background:var(--surface); border-bottom:1px solid var(--border); font-size:10px; font-weight:600; color:var(--accent); }
-.json-inspector-hdr .ji-close { margin-left:auto; cursor:pointer; color:var(--text-dim); }
-.json-inspector-hdr .ji-close:hover { color:var(--text); }
-.json-inspector pre { padding:8px; font-size:10px; overflow:auto; max-height:360px; margin:0; color:var(--text); }
-
-/* Chat page */
-.chat-thread { flex:1; overflow-y:auto; padding:8px; }
-.chat-msg { margin:4px 0; padding:6px 10px; border-radius:6px; font-size:11px; max-width:80%; }
-.chat-msg.user { background:var(--accent); color:#000; margin-left:auto; }
-.chat-msg.assistant { background:var(--surface2); }
-.chat-input-bar { display:flex; gap:4px; padding:6px 8px; border-top:1px solid var(--border); flex-shrink:0; }
-.chat-input-bar textarea { flex:1; min-height:32px; max-height:120px; resize:vertical; font-size:11px; }
-
-/* Editor page */
-.editor-panels { flex:1; display:flex; min-height:0; }
-.editor-panel { flex:1; display:flex; flex-direction:column; min-height:0; overflow-y:auto; padding:8px; }
-.editor-panel + .editor-panel { border-left:1px solid var(--border); }
-</style>
-<script>
-/* v3_components.js — Component library (source: tools/v3_components.js) */
-(function(root) {
-'use strict';
-const _components = {};
-const _esc = s => String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
-const _statusColors = { done:'green', active:'accent', pending:'text-dim', failed:'red', pass:'green', fail:'red' };
-function register(name, def) {
-  _components[name] = {
-    schema: def.schema||{}, jsonSchema: def.jsonSchema||null, fieldMap: def.fieldMap||{},
-    render: def.render||(()=>''), ascii: def.ascii||((p,w)=>['']),
-    clientSchema: def.clientSchema||null, assemblySnippet: def.assemblySnippet||null, layout: def.layout||null,
-  };
-}
-function get(name) { return _components[name]||null; }
-function list() { return Object.keys(_components); }
-function schema(name) { return _components[name]?.schema||{}; }
-// JSON-template: {"field": "type", "items": [{"sub": "type"}]}
-// Types as string values: "string", "number", "boolean"
-// Arrays: [template_item], Objects: nested
-function _legacyToTemplate(legacy) {
-  const tpl = {};
-  for (const [k, fd] of Object.entries(legacy)) {
-    const t = fd.type || 'string';
-    if (t === 'array') tpl[k] = [];
-    else if (t === 'object') tpl[k] = {};
-    else if (t === 'number') tpl[k] = 'number';
-    else if (t === 'boolean') tpl[k] = 'boolean';
-    else tpl[k] = 'string';
-  }
-  return tpl;
-}
-function template(name) {
-  const c = _components[name]; if (!c) return {};
-  if (c._template) return c._template;
-  c._template = _legacyToTemplate(c.schema);
-  return c._template;
-}
-// Keep jsonSchema for backward compat but delegate to template
-function jsonSchema(name) { return template(name); }
-function resolve(name, rawData, overrides) {
-  const comp = _components[name]; if (!comp) return {};
-  const props = {}, fmap = { ...comp.fieldMap, ...(overrides||{}) };
-  for (const [k, fd] of Object.entries(comp.schema)) {
-    const paths = String(fmap[k]||k).split('|').map(s=>s.trim()); let val;
-    for (const p of paths) { val = _gp(rawData, p); if (val != null && val !== '') break; }
-    if (val == null && 'default' in fd) val = fd.default;
-    props[k] = val;
-  }
-  return props;
-}
-function _gp(o, p) { if (!o||!p) return; const pp=p.split('.'); let v=o; for (const s of pp) { if (v==null||typeof v!=='object') return; v=v[s]; } return v; }
-function render(name, props) { const c=_components[name]; return c ? c.render(props) : `<div>[?${_esc(name)}]</div>`; }
-function ascii(name, props, w) { const c=_components[name]; return c ? c.ascii(props, w||40) : [`[?${name}]`]; }
-function _pad(s, w) { return (s+' '.repeat(w)).slice(0,w); }
-function _truncate(s, m) { s=String(s??''); return s.length>m ? s.slice(0,m-1)+'…' : s; }
-function _box(lines, w) { const o=['┌'+'─'.repeat(w-2)+'┐']; for (const l of lines) o.push('│'+_pad(l,w-2)+'│'); o.push('└'+'─'.repeat(w-2)+'┘'); return o; }
-
-// ── Schema-view: universal JSON renderer (core, always available) ──
-register('schema', { schema: { data:{type:'object',default:{},doc:'Any JSON data'} }, fieldMap:{},
-  render(p) {
-    function rv(v, depth) {
-      if (v == null) return `<span style="color:var(--text-dim);font-style:italic;">(empty)</span>`;
-      if (typeof v === 'boolean') return `<span style="color:var(--${v?'green':'red'});">${v}</span>`;
-      if (typeof v === 'number') return `<span style="color:var(--accent3);">${v}</span>`;
-      if (typeof v === 'string') {
-        if (!v) return `<span style="color:var(--text-dim);font-style:italic;">""</span>`;
-        const s = v.length > 120 ? _esc(v.slice(0,117)) + '...' : _esc(v);
-        return `<span style="color:var(--text);">${s}</span>`;
-      }
-      if (Array.isArray(v)) {
-        if (!v.length) return `<span style="color:var(--text-dim);">[]</span>`;
-        if (depth > 2) return `<span style="color:var(--text-dim);">[${v.length}]</span>`;
-        return `<div style="padding-left:10px;">${v.map((x,i) => `<div style="margin:1px 0;"><span style="color:var(--text-dim);">${i}:</span> ${rv(x, depth+1)}</div>`).join('')}</div>`;
-      }
-      if (typeof v === 'object') {
-        const keys = Object.keys(v);
-        if (!keys.length) return `<span style="color:var(--text-dim);">{}</span>`;
-        if (depth > 2) return `<span style="color:var(--text-dim);">{${keys.length}}</span>`;
-        return `<div style="padding-left:10px;">${keys.map(k => `<div style="margin:1px 0;"><span style="color:var(--accent2);">${_esc(k)}</span>: ${rv(v[k], depth+1)}</div>`).join('')}</div>`;
-      }
-      return `<span>${_esc(String(v))}</span>`;
-    }
-    // Render all props as key-value pairs
-    const keys = Object.keys(p);
-    if (!keys.length) return `<div class="node-slot" style="font-size:9px;color:var(--text-dim);padding:4px 6px;">(no data)</div>`;
-    return `<div class="node-slot" style="font-size:9px;padding:4px 6px;">${keys.map(k => `<div style="margin:1px 0;"><span style="color:var(--accent2);font-weight:600;">${_esc(k)}</span>: ${rv(p[k], 0)}</div>`).join('')}</div>`;
-  },
-  ascii(p,w) { const keys=Object.keys(p); return keys.map(k=>` ${k}: ${_truncate(JSON.stringify(p[k]),w-k.length-4)}`); } });
-
-const V3C = { register, get, list, schema, template, jsonSchema, resolve, render, ascii, _esc, _box, _pad, _truncate, _components };
-root.V3C = V3C;
-})(window);
-</script>
-<!-- Optional: JS component library (header, text, tags, etc.) — load for rich rendering -->
-<script src="/static/v3_components.js"></script>
-</head>
-<body>
-
-<!-- Top bar -->
-<div class="top-bar">
-  <h1>Workflow v3</h1>
-  <span style="color:var(--text-dim);font-size:10px;">job-based reactive</span>
-  <span style="flex:1;"></span>
-  <button class="btn sm" id="btnViewEditor">Views</button>
-  <span id="statusDot" style="width:8px;height:8px;border-radius:50%;background:var(--text-dim);"></span>
-  <span id="statusText" style="font-size:11px;color:var(--text-dim);">idle</span>
-</div>
-
-<!-- Page tabs -->
-<div class="page-tabs">
-  <button class="page-tab active" data-page="jobs">Jobs</button>
-  <button class="page-tab" data-page="chat">Chat</button>
-  <button class="page-tab" data-page="editor">Editor</button>
-</div>
-
-<!-- ═══ PAGE: Jobs ═══ -->
-<div class="page active" id="page-jobs" style="flex-direction:row;">
-  <!-- Left: Workers + Job Queues -->
-  <div class="panel panel-left">
-    <div class="panel-hdr">WORKERS <button class="btn sm" id="btnImportV2" title="Import from v2" style="margin-left:auto;font-size:9px;">v2</button> <button class="btn sm" id="btnAddWorker">+</button></div>
-    <div id="worker-add-form" style="display:none;padding:4px 8px;border-bottom:1px solid var(--border);">
-      <div style="display:flex;gap:3px;align-items:center;">
-        <input id="newWorkerUrl" placeholder="http://host:port" style="flex:1;font-size:10px;padding:2px 4px;" />
-        <input id="newWorkerRole" placeholder="role" style="width:60px;font-size:10px;padding:2px 4px;" value="generator" />
-        <button class="btn sm primary" id="btnWorkerOk" style="font-size:10px;">Add</button>
-        <button class="btn sm" id="btnWorkerCancel" style="font-size:10px;">x</button>
-      </div>
-    </div>
-    <div class="panel-body" id="workers-panel"></div>
-    <div class="panel-hdr" style="border-top:1px solid var(--border);">JOB QUEUES</div>
-    <div class="panel-body" id="queues-panel" style="flex:2;">
-      <div style="font-size:10px;color:var(--text-dim);">Run a v3 workflow to see queues</div>
-    </div>
-  </div>
-
-  <!-- Center: Card Tree -->
-  <div class="panel panel-center">
-    <div class="panel-hdr">
-      CARDS
-      <select id="renderMode" style="margin-left:auto;font-size:9px;padding:1px 3px;">
-        <option value="normal">Normal</option>
-        <option value="schema">Schema</option>
-        <option value="inspect">Inspect</option>
-      </select>
-      <span id="cardCount" style="color:var(--text-dim);font-size:10px;"></span>
-    </div>
-    <div class="panel-body" id="cards-panel"></div>
-  </div>
-
-  <!-- Right: YAML + Events -->
-  <div class="panel panel-right">
-    <div class="tab-bar">
-      <button class="tab-btn active" data-tab="yaml">YAML</button>
-      <button class="tab-btn" data-tab="events">Events</button>
-      <button class="tab-btn" data-tab="state">State</button>
-      <button class="tab-btn" data-tab="views">Views</button>
-    </div>
-
-    <!-- YAML tab -->
-    <div id="tab-yaml" style="flex:1;display:flex;flex-direction:column;min-height:0;">
-      <textarea id="yamlEditor" spellcheck="false" style="flex:1;border:none;padding:8px;font-size:11px;line-height:1.3;min-height:0;resize:none;">workflow: behavior_case_v3
-version: 3
-
-context:
-  user_prompt: >
-    написать 4 описания внешности демониц в разных образах
-    [проверить, что разные образы, разный цвет глаз,
-    разный цвет волос, разные позы,
-    в описании должны быть элементы, по которым даже без указания расы понятно, что перед тобой демоница,
-    стиль: аниме, должен быть явно указан в описании]
-
-config:
-  params_int:
-    grammar: |
-      root ::= digits term
-      digits ::= [0-9] | [0-9][0-9] | [0-9][0-9][0-9]
-      term ::= " " | "\n" | "\""
-    capture: "[0-9]+"
-    coerce: int
-  params_binary:
-    grammar: |
-      root ::= digit term
-      digit ::= "0" | "1"
-      term ::= " " | "\n" | "\""
-    capture: "[01]"
-    coerce: int
-
-payload_templates:
-  user_instruct:
-    mode: text
-    template: ${input}
-
-  user_chat:
-    mode: chat
-    messages:
-      - role: ${role}
-        content: ${input}
-
-jobs:
-  - id: claims
-    worker: analyzer
-    payload_from: user_instruct
-    payload_args:
-      input: claims($context.user_prompt)
-    priority: high
-    temp: 0.1
-    max: 2048
-    no_think: true
-
-  - id: answer
-    worker: generator
-    payload_from: user_chat
-    payload_args:
-      role: user
-      input: $context.user_prompt
-    temp: 0.7
-    max: 2048
-
-on:
-  - job: claims
-    event: done
-    do: |
-      CALL @parsed, parse_sections, @claims
-      MOV @entities, @parsed.entities
-      MOV @axioms, @parsed.axioms
-      MOV @hypotheses, @parsed.hypotheses
-
-  - job: answer
-    event: done
-    do: |
-      MOV @root.answer, @answer
-      CALL @numbered_answer, numbered, @answer
-    then:
-      - enqueue: table
-
-  - job: table
-    event: done
-    do: |
-      CALL @entity_nodes, parse_table_rows, @table
-      MOV @root.entities, @entity_nodes
-    then:
-      - enqueue: start_line_probe
-        for_each: entity_nodes
-
-  - job: start_line_probe
-    event: done
-    do: |
-      MOV @item._startNum, @_event.result
-      CALL @item._firstLine, slice_lines, @answer, @item._startNum, @item._startNum
-    then:
-      - enqueue: end_line_probe
-        for_each: entity_nodes
-
-  - job: end_line_probe
-    event: done
-    do: |
-      MOV @item.endLineNumber, @_event.result
-      CALL @item.answer, slice_lines, @answer, @item._startNum, @item.endLineNumber
-    then:
-      - enqueue: confirm_probe
-
-  - job: confirm_probe
-    event: done
-    do: |
-      MOV @item.confirmed, @_event.result
-    then:
-      - enqueue: style_check
-
-  - job: style_check
-    event: done
-    do: |
-      MOV @item.style_check, @_event.result
-    then:
-      - enqueue: reaction_check
-
-  - job: reaction_check
-    event: done
-    do: |
-      MOV @item.reaction, @_event.result
-      CALL @item.reactionStatus, check_status, @_event.result
-    then:
-      - enqueue: comfyui_gen
-
-job_templates:
-  table:
-    worker: analyzer
-    payload_from: user_instruct
-    payload_args:
-      input: table($answer)
-    temp: 0.1
-    max: 2048
-    no_think: true
-
-  start_line_probe:
-    worker: generator
-    mode: probe_continue
-    grammar: $config.params_int.grammar
-    capture:
-      regex: $config.params_int.capture
-      coerce: $config.params_int.coerce
-    stop: [" ", "\n", "\""]
-    messages:
-      - user: ${numbered_answer}
-      - assistant: |-
-          <think>
-          I will split the text into blocks.
-          The description titled "${item._title}" starts at line number "
-    temp: 0
-    max: 4
-
-  end_line_probe:
-    worker: generator
-    mode: probe_continue
-    grammar: $config.params_int.grammar
-    capture:
-      regex: $config.params_int.capture
-      coerce: $config.params_int.coerce
-    stop: [" ", "\n", "\""]
-    messages:
-      - user: ${numbered_answer}
-      - assistant: |-
-          <think>
-          Разделю текст на блоки.
-          Описание "${item._title}" начинается со строки
-          под номером "${item._startNum}" "${item._firstLine}"
-          и длится до строки под номером "line number:
-    temp: 0
-    max: 4
-
-  confirm_probe:
-    worker: generator
-    mode: probe_continue
-    grammar: $config.params_binary.grammar
-    capture:
-      regex: $config.params_binary.capture
-      coerce: $config.params_binary.coerce
-    stop: [" ", "\n", "\""]
-    messages:
-      - user: ${numbered_answer}
-      - assistant: |-
-          <think>
-          Описание "${item._title}":
-          ${item.answer}
-          ((answer generated) == true) ===
-    temp: 0
-    max: 2
-
