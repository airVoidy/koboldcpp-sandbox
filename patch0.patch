-// ── Field mapping (from gui_builder) ──
-const _fieldMap = {
-  title: { title:'title', name:'name', status:'status', type:'type', time:'time', children:'children', tags:'tags' },
-  text_area: { text:'answer', fallback:'question', think:'answerThink', textStatus:'answerStatus' },
-  tags: { tags:'tags' },
-  thread: { items:'thread', open:'threadOpen' },
-  reactions: { items:'reactions' },
-  list: {},
-  children: { items:'children', cardTemplate:'card_template' },
-  buttons: {},
-  form: { fields:'questionForm' },
-};
