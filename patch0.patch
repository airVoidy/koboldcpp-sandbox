-        else if (k==='y') c.y = +v;
-        else if (k==='w') c.w = +v;
-        else if (k==='h') c.h = +v;
-      }
-    }
-    return c;
-  }
-  // reparent <target_parent> — move selected panel under target
-  if (cmd === 'reparent') return { cmd:'reparent', target:tokens[1], _ctx:ctx };
-  // reorder <index> — move selected panel to index in parent's children
-  if (cmd === 'reorder') return { cmd:'reorder', index:+tokens[1]||0, _ctx:ctx };
-  // rename <new_name> — rename panel, update all refs
-  if (cmd === 'rename') return { cmd:'rename', newName:tokens[1], _ctx:ctx };
-  if (cmd === 'select') { _ctx = tokens[1]||'screen'; clog(`\u2192 ${_ctx}`, 'cmd-ok'); return { cmd:'select', target:_ctx }; }
-  if (cmd === 'up') { const p=_ctx?findParentPanel(panels[_ctx]):null; _ctx=p?p.name:'screen'; clog(`\u2192 ${_ctx}`, 'cmd-ok'); return null; }
-  if (cmd === 'root') { _ctx='screen'; clog(`\u2192 screen`, 'cmd-ok'); return null; }
-  if (cmd === 'get' || cmd === 'ls') return { cmd:'get', what:tokens[1], _ctx:ctx };
-  if (cmd === 'find') return { cmd:'find', pattern:tokens[1]||'*', _ctx:ctx };
-  clog(`unknown: ${cmd}`, 'cmd-err');
-  return null;
-}
