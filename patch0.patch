-    const ch=c<val.length?val[c]:' ';
-    const cl=(c===cursorPos&&cursorVisible)?'c-cursor':(z.style||'');
-    panelWrite(p,z.y,z.x+c,ch,cl);
-  }
-  if(cursorPos===val.length&&cursorPos<z.w&&cursorVisible) panelWrite(p,z.y,z.x+cursorPos,'\u2588','c-cursor');
-  draw();
-}
