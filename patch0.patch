-function parseCmd(line) {
-  line = line.trim();
-  if (!line || line.startsWith(';')) return null;
-  const tokens = asmTokenize(line);
-  if (!tokens.length) return null;
-  const cmd = tokens[0];
-  const ctx = _ctx || 'screen';
-
-  if (cmd === 'panel') return { cmd:'panel', name:tokens[1], w:+tokens[2]||20, h:+tokens[3]||10, _ctx:ctx };
-  if (cmd === 'move') return { cmd:'move', x:+tokens[1]||0, y:+tokens[2]||0, _ctx:ctx };
-  if (cmd === 'resize') return { cmd:'resize', w:+tokens[1]||10, h:+tokens[2]||10, _ctx:ctx };
-  if (cmd === 'set') return { cmd:'set', prop:tokens[1], value: tokens[2]==='true'?true:tokens[2]==='false'?false:tokens[2], _ctx:ctx };
-  if (cmd === 'del') return { cmd:'del', _ctx:ctx };
-  if (cmd === 'write') return { cmd:'write', row:+tokens[1]||0, col:+tokens[2]||0, text:tokens[3]||'', color:tokens[4]||'', _ctx:ctx };
-  if (cmd === 'clear') return { cmd:'clear', _ctx:ctx };
-  if (cmd === 'zone') {
-    const z = { cmd:'zone', x:+tokens[1]||0, y:+tokens[2]||0, w:+tokens[3]||1, h:+tokens[4]||1, type:tokens[5]||'button', _ctx:ctx };
