-  if (!el) return;
-  let h = '';
-
-  h += `<div style="color:var(--accent);font-weight:600;margin-bottom:4px;">TEMPLATES</div>`;
-  for (const [name, tmpl] of Object.entries(_cardTemplates)) {
-    const typeCounts = {};
-    h += `<div style="margin-bottom:4px;"><span style="color:var(--accent);font-weight:600;">${esc(name)}</span> <span style="color:var(--text-dim);">${tmpl.slots.length} slots</span></div>`;
-    h += `<div style="padding-left:8px;color:var(--text-dim);margin-bottom:2px;">`;
-    for (const s of tmpl.slots) {
-      const n = (typeCounts[s.type] = (typeCounts[s.type] || 0) + 1);
-      const slotId = s.type + '.' + n;
-      const comp = s.component || 'schema';
-      h += `<div>\u2022 <span style="color:var(--accent2);">${esc(slotId)}</span>`;
-      if (comp !== s.type) h += ` <span style="font-size:9px;color:var(--text-dim);">[${esc(comp)}]</span>`;
-      if (typeof s.assemble === 'function') h += ` <span style="font-size:9px;color:var(--green);">fn</span>`;
