-        slots: [],
-        _ui: { collapsed: false },
-        _view: 'job',
-      };
-      reassembleNode(nodes[jid]);
-      changed = true;
-    } else {
-      const nd = nodes[jid];
-      const oldStatus = nd.data.status, oldAnswer = nd.data.answer;
-      nd.data.status = job.status;
-      if (job.result) nd.data.answer = job.result;
-      nd.data.worker = job.worker;
-      nd.data.priority = job.priority;
-      if (nd.data.status !== oldStatus || nd.data.answer !== oldAnswer) {
-        reassembleNode(nd);
-        changed = true;
-      }
-    }
-  }
-
-  // Merge entity data from state (enriched entities, reactions, images)
-  const items = status.state?.items;
-  if (Array.isArray(items)) {
-    for (let i = 0; i < items.length; i++) {
-      const item = items[i];
-      const key = item._id || item.name || `entity.${i}`;
-      if (!nodes[key]) {
-        nodes[key] = {
-          id: key,
-          data: { ...item, id: key },
-          children: [],
-          slots: [],
-          _ui: { collapsed: false },
-          _view: 'entity',
-        };
-        reassembleNode(nodes[key]);
-        changed = true;
-      } else {
-        const nd = nodes[key];
-        let dataChanged = false;
-        for (const [k, v] of Object.entries(item)) {
-          if (k !== '_id' && v != null && nd.data[k] !== v) {
-            nd.data[k] = v;
-            dataChanged = true;
-          }
-        }
-        if (dataChanged) { reassembleNode(nd); changed = true; }
-      }
-    }
-  }
-
-  if (changed) { saveNodes(); renderCards(); }
-}
