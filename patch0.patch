-    html += `<div class="timeline">`;
-    for (const [worker, wJobs] of Object.entries(byWorker)) {
-      html += `<div class="tl-lane"><div class="tl-label" title="${esc(worker)}">${esc(worker)}</div><div class="tl-track">`;
-      for (const j of wJobs) {
-        const s = j.started_at || tMin;
-        const e = j.finished_at || (j.status === 'active' ? now : s + 0.5);
-        const left = ((s - tMin) / span * 100).toFixed(1);
-        const width = Math.max(((e - s) / span * 100), 1).toFixed(1);
