-    }
-    h += `</div>`;
-  }
-
-  h += `<div style="color:var(--green);font-weight:600;margin:6px 0 4px;">VIEWS</div>`;
-  for (const [name, view] of Object.entries(_views)) {
-    h += `<div style="margin-bottom:2px;"><span style="color:var(--green);font-weight:600;">${esc(name)}</span> <span style="color:var(--text-dim);">\u2192 ${esc(view.template)}</span></div>`;
-    const ov = view.overrides;
