-// ══════════════════════════════════════════════════════════
-//  CHAR-GRID SLOT RENDERERS (ported from AABB pipeline)
-// ══════════════════════════════════════════════════════════
-function _truncateStr(s, max) { s = String(s ?? ''); return s.length > max ? s.slice(0, max - 1) + '\u2026' : s; }
-function _wordWrap(text, w) {
-  const lines = []; const words = text.split(/\s+/);
-  let line = '';
-  for (const word of words) {
-    if (line.length + word.length + 1 > w) { if (line) lines.push(line); line = word; }
-    else line = line ? line + ' ' + word : word;
-  }
-  if (line) lines.push(line);
-  return lines.length ? lines : [''];
-}
-
-const _charSlotRenderers = {
