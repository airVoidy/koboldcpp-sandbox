-function _wireViewsTab(el) {
-  // Toggle item bodies
-  el.querySelectorAll('.ve-item-hdr').forEach(hdr => {
-    hdr.addEventListener('click', (e) => {
-      if (e.target.classList.contains('ve-del')) return;
-      const body = hdr.nextElementSibling;
-      if (body) body.classList.toggle('open');
-    });
-  });
-
-  // ── TEMPLATE actions ──
-  el.querySelectorAll('[data-ve="add-template"]').forEach(btn => {
-    btn.addEventListener('click', function() {
-      _inlinePrompt(this, 'template name', (name) => {
-      if (_cardTemplates[name]) return;
-      _cardTemplates[name] = { slots: [{ type: 'header' }] };
-      _saveCustomData(); renderViewsTab(); renderCards();
-      });
-    });
-  });
-
-  el.querySelectorAll('[data-ve="del-template"]').forEach(btn => {
-    btn.addEventListener('click', () => {
-      delete _cardTemplates[btn.dataset.name];
-      _saveCustomData(); renderViewsTab(); renderCards();
-    });
-  });
-
-  el.querySelectorAll('[data-ve="add-slot"]').forEach(btn => {
-    btn.addEventListener('click', () => {
-      _cardTemplates[btn.dataset.tpl].slots.push({ type: 'data' });
-      _saveCustomData(); renderViewsTab(); renderCards();
-    });
-  });
-
-  el.querySelectorAll('[data-ve="del-slot"]').forEach(btn => {
-    btn.addEventListener('click', () => {
-      _cardTemplates[btn.dataset.tpl].slots.splice(+btn.dataset.idx, 1);
-      _saveCustomData(); renderViewsTab(); renderCards();
-    });
-  });
-
-  el.querySelectorAll('[data-ve="move-slot-up"]').forEach(btn => {
-    btn.addEventListener('click', () => {
-      const slots = _cardTemplates[btn.dataset.tpl].slots;
-      const i = +btn.dataset.idx;
-      if (i > 0) { [slots[i - 1], slots[i]] = [slots[i], slots[i - 1]]; }
-      _saveCustomData(); renderViewsTab(); renderCards();
-    });
-  });
-
-  // ── Slot type name (semantic, free text) ──
-  el.querySelectorAll('[data-ve="slot-type-name"]').forEach(inp => {
-    inp.addEventListener('change', () => {
-      const slot = _cardTemplates[inp.dataset.tpl].slots[+inp.dataset.idx];
-      slot.type = inp.value.trim() || 'data';
-      _saveCustomData(); renderViewsTab(); renderCards();
-    });
-  });
-
-  // ── Assembly toggle + editor ──
-  el.querySelectorAll('[data-ve="toggle-asm"]').forEach(btn => {
-    btn.addEventListener('click', (e) => {
-      e.stopPropagation();
-      const ta = el.querySelector(`textarea[data-ve="slot-asm"][data-tpl="${btn.dataset.tpl}"][data-idx="${btn.dataset.idx}"]`);
-      if (ta) ta.style.display = ta.style.display === 'none' ? 'block' : 'none';
-    });
-  });
-  el.querySelectorAll('[data-ve="slot-asm"]').forEach(ta => {
-    ta.addEventListener('change', () => {
-      const slot = _cardTemplates[ta.dataset.tpl].slots[+ta.dataset.idx];
-      slot.asm = ta.value;
-      delete slot.assemble; // DSL replaces JS fn
-      ta.style.borderColor = ta.value.trim() ? 'var(--green)' : 'var(--border)';
-      _saveCustomData(); renderCards();
-    });
-  });
-
-  // ── VIEW actions ──
-  el.querySelectorAll('[data-ve="add-view"]').forEach(btn => {
-    btn.addEventListener('click', function() {
-      _inlinePrompt(this, 'view name', (name) => {
-      if (_views[name]) return;
-      _views[name] = { template: _templateNames()[0] || 'job' };
-      _saveCustomData(); renderViewsTab();
-      });
-    });
-  });
-
-  el.querySelectorAll('[data-ve="del-view"]').forEach(btn => {
-    btn.addEventListener('click', () => {
-      delete _views[btn.dataset.name];
-      _saveCustomData(); renderViewsTab();
-    });
-  });
-
-  el.querySelectorAll('[data-ve="view-tpl"]').forEach(sel => {
-    sel.addEventListener('change', () => {
-      _views[sel.dataset.view].template = sel.value;
-      _saveCustomData(); renderCards();
-    });
-  });
-}
-
-// ── Read-only Views info panel (right sidebar) ──
