-        html += hasOverride ? ` <span style="color:var(--green);">override fn</span>` : ` <span style="color:var(--text-dim);">(template)</span>`;
-        html += `</div>`;
-      }
-    }
-    html += `</div></div>`;
-  }
-  html += `</div>`;
-
-  elL.innerHTML = html;
-
-  // ── COMPONENT SCHEMAS (right column, from V3C.jsonSchema) ──
-  let htmlR = '';
