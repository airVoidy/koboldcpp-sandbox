-    return z;
-  }
-  if (cmd === 'zone_del') return { cmd:'zone_del', index:+tokens[1]||0, _ctx:ctx };
-  if (cmd === 'action') {
-    // action name { ... } — collect block
-    const name = tokens[1];
-    let asm = tokens.slice(2).join(' ');
-    if (asm.startsWith('{')) asm = asm.slice(1); if (asm.endsWith('}')) asm = asm.slice(0,-1);
-    return { cmd:'action', name, asm: asm.trim(), _ctx:ctx };
-  }
-  if (cmd === 'action_del') return { cmd:'action_del', name:tokens[1], _ctx:ctx };
-  if (cmd === 'data') {
-    // Take raw text after "data <path> " to preserve JSON
-    const pathToken = tokens[1];
-    const pathEnd = line.indexOf(pathToken) + pathToken.length;
-    let rawVal = line.slice(pathEnd).trim();
-    let v = rawVal;
-    try { v = JSON.parse(rawVal); } catch(_) {}
-    return { cmd:'data', path:pathToken, value:v };
-  }
-  if (cmd === 'load') return { cmd:'load', path:tokens[1], key:tokens[2], default:tokens[3] };
-  if (cmd === 'render') return { cmd:'render', _ctx:ctx };
-  // run <action_name> [data] — execute panel action (goes through replay)
-  if (cmd === 'run') {
-    let data = tokens[2];
-    if (data !== undefined) { try { data = JSON.parse(data); } catch(_) {} }
-    return { cmd:'run', action:tokens[1], data, _ctx:ctx };
-  }
-  // extract <new_name> [zones=0,2,3] [rows=4-8] — move part of panel to new child
-  if (cmd === 'extract') {
-    const c = { cmd:'extract', newName:tokens[1], _ctx:ctx };
-    for (let i=2; i<tokens.length; i++) {
-      const t=tokens[i], eq=t.indexOf('=');
-      if (eq>0) {
-        const k=t.slice(0,eq), v=t.slice(eq+1);
-        if (k==='zones') c.zoneIndices = v.split(',').map(Number);
-        else if (k==='rows') { const [a,b]=v.split('-').map(Number); c.rowStart=a; c.rowEnd=b; }
