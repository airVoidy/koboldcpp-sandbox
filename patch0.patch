-    el.innerHTML = '<div style="font-size:10px;color:var(--text-dim);">No queues</div>';
-    return;
-  }
-
-  // Chip view (compact queue list)
-  let html = '';
-  for (const [worker, qJobs] of Object.entries(queues)) {
-    html += `<div class="lane"><div class="lane-hdr">${esc(worker)}</div>`;
-    for (const j of qJobs) {
-      html += `<span class="job-chip ${j.status}">${esc(j.id)}</span>`;
-    }
-    if (!qJobs.length) html += `<span style="font-size:10px;color:var(--text-dim);">empty</span>`;
-    html += `</div>`;
-  }
-
-  // Timeline view (horizontal bars with time)
-  if (jobs && Object.keys(jobs).length) {
-    const allJobs = Object.values(jobs);
-    const now = Date.now() / 1000;
-    let tMin = Infinity, tMax = -Infinity;
-    for (const j of allJobs) {
-      if (j.started_at && j.started_at < tMin) tMin = j.started_at;
-      if (j.finished_at && j.finished_at > tMax) tMax = j.finished_at;
-    }
-    if (tMin === Infinity) tMin = now - 1;
-    if (tMax === -Infinity || tMax < tMin + 1) tMax = now;
-    const span = tMax - tMin || 1;
