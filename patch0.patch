-// ── Helpers ──
-function truncate(s, w) { s = String(s||''); return s.length <= w ? s : s.slice(0, w - 1) + '\u2026'; }
-function wordWrap(text, w) {
-  if (!text) return [''];
-  const lines = [];
-  for (const raw of String(text).split('\n')) {
-    if (raw.length <= w) { lines.push(raw); continue; }
-    let i = 0;
-    while (i < raw.length) { lines.push(raw.slice(i, i + w)); i += w; }
-  }
-  return lines;
-}
