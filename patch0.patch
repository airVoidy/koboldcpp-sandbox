-function startCursorBlink() { stopCursorBlink(); cursorVisible=true; cursorInterval=setInterval(()=>{cursorVisible=!cursorVisible;renderFocusedInput();},530); }
-function stopCursorBlink() { if(cursorInterval){clearInterval(cursorInterval);cursorInterval=null;} cursorVisible=false; }
