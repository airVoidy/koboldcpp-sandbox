-      }
-      // Now marker
-      const nowPct = ((now - tMin) / span * 100).toFixed(1);
-      if (nowPct > 0 && nowPct < 100) {
-        html += `<div class="tl-now" style="left:${nowPct}%;"></div>`;
-      }
-      html += `</div></div>`;
-    }
-    html += `</div></div>`;
-  }
