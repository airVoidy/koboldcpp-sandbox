 <script>
-'use strict';
-
-/* ════════════════════════════════════════════════════════════════════════════
-   AABB v2 — Panel VTerm + Hot Zones + Data Layer + Assembly
-   ════════════════════════════════════════════════════════════════════════════ */
-
-// ── Char size ──────────────────────────────────────────────────────────────
-const _m = document.createElement('span');
-_m.style.cssText = 'position:absolute;left:-9999px;font:14px/1.25 Consolas,Monaco,"Courier New",monospace;white-space:pre;';
-_m.textContent = 'X';
-document.body.appendChild(_m);
-const CW = _m.getBoundingClientRect().width, CH = _m.getBoundingClientRect().height;
-document.body.removeChild(_m);
-
-// ══════════════════════════════════════════════════════════════════════════
-//  DATA LAYER — scoped store with change events
-// ══════════════════════════════════════════════════════════════════════════
-
-const _data = {};
-const _dataListeners = {}; // path → Set<callback>
-
-const Data = {
-  set(path, value) {
-    const parts = path.split('.');
-    let obj = _data;
-    for (let i = 0; i < parts.length - 1; i++) {
-      if (!(parts[i] in obj) || typeof obj[parts[i]] !== 'object') obj[parts[i]] = {};
-      obj = obj[parts[i]];
-    }
-    obj[parts[parts.length - 1]] = value;
-    this._notify(path);
-  },
-
-  get(path) {
-    const parts = path.split('.');
-    let obj = _data;
-    for (const p of parts) {
-      if (obj == null || typeof obj !== 'object') return undefined;
-      obj = obj[p];
-    }
-    return obj;
-  },
-
-  watch(path, fn) {
-    if (!_dataListeners[path]) _dataListeners[path] = new Set();
-    _dataListeners[path].add(fn);
-    return () => _dataListeners[path].delete(fn);
-  },
-
-  _notify(path) {
-    // Notify exact match + parent paths
-    for (const [p, fns] of Object.entries(_dataListeners)) {
-      if (path === p || path.startsWith(p + '.') || p.startsWith(path + '.')) {
-        for (const fn of fns) fn(path);
-      }
-    }
-  },
-
-  dump() {
-    return JSON.parse(JSON.stringify(_data));
-  },
-
-  load(key, fallback) {
-    try {
-      const raw = localStorage.getItem('aabb_' + key);
-      if (raw) return JSON.parse(raw);
-    } catch (_) {}
-    return fallback;
-  },
-
-  save(key, value) {
-    try { localStorage.setItem('aabb_' + key, JSON.stringify(value)); } catch (_) {}
-  }
-};
-
-// ══════════════════════════════════════════════════════════════════════════
-//  PANEL MODEL — virtual terminal + hot zones
-// ══════════════════════════════════════════════════════════════════════════
-
-const panels = {};  // name → Panel
-
-function createPanel(name, w, h) {
-  const buf = [];
-  for (let r = 0; r < h; r++) {
-    const row = [];
-    for (let c = 0; c < w; c++) row.push({ ch: ' ', cl: '' });
-    buf.push(row);
-  }
-  const panel = {
-    name, w, h, buf,
-    scrollX: 0, scrollY: 0,
-    zones: [],           // runtime zones (from asm.render + authored)
-    authoredZones: [],   // persisted zones (created via GUI, first-class)
-    children: [],        // { panel, x, y, w, h } — child panel placements
-    border: true,
-    borderColor: '#3b4261',
-    label: name,
-    // view state
-    collapsed: false,
-    // assembly
-    asm: '',
-    asmActions: {},
-  };
-  panels[name] = panel;
-  return panel;
-}
-
-function panelWrite(panel, row, col, text, cl) {
-  if (typeof panel === 'string') panel = panels[panel];
-  if (!panel) return;
-  // Grow buffer if needed
-  while (panel.buf.length <= row) {
-    const r = [];
-    for (let c = 0; c < panel.w; c++) r.push({ ch: ' ', cl: '' });
-    panel.buf.push(r);
-  }
-  const r = panel.buf[row];
-  for (let i = 0; i < text.length; i++) {
-    const c = col + i;
-    if (c < 0) continue;
-    while (r.length <= c) r.push({ ch: ' ', cl: '' });
-    r[c] = { ch: text[i], cl: cl || '' };
-  }
-}
-
-function panelClear(panel) {
-  if (typeof panel === 'string') panel = panels[panel];
-  if (!panel) return;
-  for (let r = 0; r < panel.buf.length; r++)
-    for (let c = 0; c < panel.buf[r].length; c++)
-      panel.buf[r][c] = { ch: ' ', cl: '' };
-}
-
-function zoneAdd(panel, y, x, w, h, type, action, data, style) {
-  if (typeof panel === 'string') panel = panels[panel];
-  if (!panel) return;
-  panel.zones.push({ x, y, w: w || 1, h: h || 1, type, action, data, style });
-}
-
-function zoneClear(panel) {
-  if (typeof panel === 'string') panel = panels[panel];
-  if (!panel) return;
-  // Clear render-created zones, keep authored zones
-  panel.zones = panel.authoredZones.map(z => ({ ...z }));
-}
-
-function addChildPanel(parent, child, x, y, w, h) {
-  if (typeof parent === 'string') parent = panels[parent];
-  if (typeof child === 'string') child = panels[child];
-  if (!parent || !child) return;
-  parent.children.push({ panel: child, x, y, w: w || child.w, h: h || child.h });
-}
-
-// ══════════════════════════════════════════════════════════════════════════
-//  GLOBAL GRID + RENDERER
-// ══════════════════════════════════════════════════════════════════════════
-
-let COLS = 0, ROWS = 0, G = [];
-const textLayer = document.getElementById('text-layer');
-const svgLayer = document.getElementById('svg-layer');
-const overlaySvg = document.getElementById('overlay-svg');
-
-function calcGrid() {
-  const r = document.getElementById('canvas').getBoundingClientRect();
-  COLS = Math.floor(r.width / CW);
-  ROWS = Math.floor(r.height / CH);
-}
-
-function initGrid() {
-  G = [];
-  for (let r = 0; r < ROWS; r++) {
-    const row = [];
-    for (let c = 0; c < COLS; c++) row.push({ ch: ' ', cl: '' });
-    G.push(row);
-  }
-}
-
-function compositePanel(panel, gx, gy, vw, vh) {
-  const buf = panel.buf;
-  const sy = panel.scrollY, sx = panel.scrollX;
-  for (let r = 0; r < vh; r++) {
-    const srcR = sy + r;
-    if (srcR < 0 || srcR >= buf.length) continue;
-    const srcRow = buf[srcR];
-    for (let c = 0; c < vw; c++) {
-      const srcC = sx + c;
-      if (srcC < 0 || srcC >= srcRow.length) continue;
-      const dx = gx + c, dy = gy + r;
-      if (dx >= 0 && dx < COLS && dy >= 0 && dy < ROWS) {
-        G[dy][dx] = srcRow[srcC];
-      }
-    }
-  }
-  // Recurse into child panels
-  for (const ch of panel.children) {
-    compositePanel(ch.panel, gx + ch.x, gy + ch.y, ch.w, ch.h);
-  }
-}
-
-function flushGrid() {
-  let html = '';
-  for (let r = 0; r < ROWS; r++) {
-    let c = 0;
-    while (c < COLS) {
-      const cl = G[r][c].cl;
-      let run = '';
-      while (c < COLS && G[r][c].cl === cl) { run += escH(G[r][c].ch); c++; }
-      html += cl ? `<span class="${cl}">${run}</span>` : run;
-    }
-    html += '\n';
-  }
-  textLayer.innerHTML = html;
-}
-
-function escH(s) { return s === '<' ? '&lt;' : s === '>' ? '&gt;' : s === '&' ? '&amp;' : s; }
-
-// ── SVG borders ────────────────────────────────────────────────────────────
-function drawBorders() {
-  let svg = '';
-  function walkPanel(panel, gx, gy, vw, vh) {
-    if (panel.border) {
-      const x = gx * CW, y = gy * CH, w = vw * CW, h = vh * CH;
-      svg += `<rect x="${x}" y="${y}" width="${w}" height="${h}" fill="none" stroke="${panel.borderColor}" stroke-width="1" rx="2"/>`;
-      if (panel.label) {
-        svg += `<text x="${x + 8}" y="${y - 3}" fill="${panel.borderColor}" font-size="10" font-family="Consolas,monospace">${escH(panel.label)}</text>`;
-      }
-    }
-    for (const ch of panel.children) {
-      walkPanel(ch.panel, gx + ch.x, gy + ch.y, ch.w, ch.h);
-    }
-  }
-  if (rootPanel) walkPanel(rootPanel, 0, 0, COLS, ROWS);
-  svgLayer.setAttribute('width', COLS * CW);
-  svgLayer.setAttribute('height', ROWS * CH);
-  svgLayer.innerHTML = svg;
-}
-
-// ── Overlay ────────────────────────────────────────────────────────────────
-let selectedZone = null; // for inspect/panels tabs
-
-function drawOverlay() {
-  let svg = '';
-  overlaySvg.setAttribute('width', COLS * CW);
-  overlaySvg.setAttribute('height', ROWS * CH);
-
-  // Highlight selected panel
-  if (selectedPanel && selectedPanel !== rootPanel) {
-    const pos = getPanelGlobalPos(selectedPanel);
-    if (pos) {
-      const x = pos.gx * CW, y = pos.gy * CH, w = pos.vw * CW, h = pos.vh * CH;
-      svg += `<rect x="${x}" y="${y}" width="${w}" height="${h}" fill="none" stroke="#e0af68" stroke-width="2" stroke-dasharray="4,2" rx="2"/>`;
-    }
-  }
-
-  // Show hot zones on canvas (all tabs except preview)
-  if (activeTab !== 'preview') {
-    function walkZones(panel, gx, gy) {
-      for (const z of panel.zones) {
-        const zx = (gx + z.x) * CW, zy = (gy + z.y) * CH;
-        const zw = z.w * CW, zh = z.h * CH;
-        const isSel = z === selectedZone;
-        if (z.type === 'button') {
-          svg += `<rect x="${zx}" y="${zy}" width="${zw}" height="${zh}" fill="${isSel ? 'rgba(255,158,100,0.15)' : 'rgba(255,158,100,0.06)'}" stroke="${isSel ? '#ff9e64' : '#ff9e6440'}" stroke-width="${isSel ? 1.5 : 0.5}" rx="1"/>`;
-        } else if (z.type === 'input') {
-          svg += `<rect x="${zx}" y="${zy}" width="${zw}" height="${zh}" fill="${isSel ? 'rgba(122,162,247,0.15)' : 'rgba(122,162,247,0.06)'}" stroke="${isSel ? '#7aa2f7' : '#7aa2f740'}" stroke-width="${isSel ? 1.5 : 0.5}" rx="1"/>`;
-        } else {
-          svg += `<rect x="${zx}" y="${zy}" width="${zw}" height="${zh}" fill="rgba(125,207,255,0.05)" stroke="#7dcfff30" stroke-width="0.5" rx="1"/>`;
-        }
-        // Label
-        if (z.action) {
-          svg += `<text x="${zx + 1}" y="${zy - 2}" fill="${z.type === 'button' ? '#ff9e64' : '#7aa2f7'}" font-size="8" font-family="Consolas,monospace" opacity="0.7">${escH(z.action)}</text>`;
-        }
-      }
-      for (const ch of panel.children) walkZones(ch.panel, gx + ch.x, gy + ch.y);
-    }
-    if (rootPanel) walkZones(rootPanel, 0, 0);
-  }
-
-  // Focused input underline (preview)
-  if (activeTab === 'preview' && focusedZone) {
-    const pos = getPanelGlobalPos(focusedZone._panel);
-    if (pos) {
-      const x = (pos.gx + focusedZone.x) * CW;
-      const y = (pos.gy + focusedZone.y + focusedZone.h) * CH - 1;
-      const w = focusedZone.w * CW;
-      svg += `<line x1="${x}" y1="${y}" x2="${x + w}" y2="${y}" stroke="var(--accent)" stroke-width="1"/>`;
-    }
-  }
-
-  overlaySvg.innerHTML = svg;
-}
-
-// ── Hit test: pixel → panel + zone ─────────────────────────────────────────
-function hitTestPanel(px, py, panel, gx, gy, vw, vh) {
-  // Check children first (deeper = higher priority)
-  for (let i = panel.children.length - 1; i >= 0; i--) {
-    const ch = panel.children[i];
-    const cx = gx + ch.x, cy = gy + ch.y;
-    if (px >= cx && px < cx + ch.w && py >= cy && py < cy + ch.h) {
-      const r = hitTestPanel(px, py, ch.panel, cx, cy, ch.w, ch.h);
-      if (r) return r;
-    }
-  }
-  // Check zones in this panel
-  const localX = px - gx + panel.scrollX;
-  const localY = py - gy + panel.scrollY;
-  for (let i = panel.zones.length - 1; i >= 0; i--) {
-    const z = panel.zones[i];
-    if (localX >= z.x && localX < z.x + z.w && localY >= z.y && localY < z.y + z.h) {
-      return { panel, zone: z, localX, localY, gx, gy };
-    }
-  }
-  // Return panel itself
-  if (px >= gx && px < gx + vw && py >= gy && py < gy + vh) {
-    return { panel, zone: null, localX, localY, gx, gy };
-  }
-  return null;
-}
-
-function getPanelGlobalPos(panel) {
-  if (panel === rootPanel) return { gx: 0, gy: 0, vw: COLS, vh: ROWS };
-  // Search tree
-  function find(p, gx, gy) {
-    for (const ch of p.children) {
-      if (ch.panel === panel) return { gx: gx + ch.x, gy: gy + ch.y, vw: ch.w, vh: ch.h };
-      const r = find(ch.panel, gx + ch.x, gy + ch.y);
-      if (r) return r;
-    }
-    return null;
-  }
-  return rootPanel ? find(rootPanel, 0, 0) : null;
-}
-
-// ── Full draw ──────────────────────────────────────────────────────────────
-let rootPanel = null;
-
-function draw() {
-  if (!rootPanel) return;
-  calcGrid();
-  initGrid();
-  compositePanel(rootPanel, 0, 0, COLS, ROWS);
-  flushGrid();
-  drawBorders();
-  drawOverlay();
-  const pc = Object.keys(panels).length;
-  const zc = Object.values(panels).reduce((s, p) => s + p.zones.length, 0);
-  document.getElementById('status-info').textContent = `${COLS}x${ROWS} | ${pc} panels | ${zc} zones`;
-}
-
-// ══════════════════════════════════════════════════════════════════════════
-//  CLIENT-SIDE ASSEMBLY INTERPRETER
-//  Opcodes: MOV, CALL, EACH, CMP, JIF, NOP
