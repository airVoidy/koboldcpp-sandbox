-
-<!-- Chat Tab -->
-<div class="page active" id="page-chat">
-  <div class="main-layout">
-    <div class="sidebar">
-      <div class="sidebar-hdr">Channels</div>
-      <div class="sidebar-body" id="channel-list"></div>
-      <div class="new-ch">
-        <input id="new-ch-input" placeholder="new channel" onkeydown="if(event.key==='Enter')createChannel()">
-        <button class="btn sm" onclick="createChannel()">+</button>
-      </div>
-    </div>
-    <div class="content-area">
-      <div class="channel-label" id="channel-label">Select or create a channel</div>
-      <div class="chat-thread" id="chat-thread">
-        <div class="chat-empty">No channel selected</div>
-      </div>
-      <div class="chat-input-bar">
-        <textarea id="chat-input" placeholder="Type a message..." onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendMessage()}"></textarea>
-        <button class="btn primary" onclick="sendMessage()">Send</button>
-      </div>
-    </div>
-  </div>
-</div>
-
-<!-- Shell Tab -->
-<div class="page" id="page-shell">
-  <div class="shell-layout">
-    <div class="shell-output" id="shell-output"></div>
-    <div class="shell-input-bar">
-      <span style="color:var(--green)">$</span>
-      <input id="shell-input" placeholder="/ls, /mk channel lobby, /select lobby, /post hello ..." onkeydown="if(event.key==='Enter')runShell()">
-      <button class="btn sm" onclick="runShell()">Run</button>
-    </div>
-  </div>
-</div>
-
-<!-- FS Tab -->
-<div class="page" id="page-fs">
-  <div class="node-list" id="fs-view"></div>
-</div>
-
-<!-- Raw Tab -->
-<div class="page" id="page-raw">
-  <div class="data-view">
-    <pre id="raw-view" class="empty">Send a command to see raw responses</pre>
-  </div>
-</div>
-
-<div class="status-bar" id="status-bar">Ready</div>
-
-<script>
-// 'use strict' removed — functions must be global for onclick handlers
-
-function esc(s) { return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
-
-// ══════════════════════════════════════════════════════════
-//  State
-// ══════════════════════════════════════════════════════════
-
-let activeChannelPath = null;  // e.g. "pchat/channels/lobby"
-let activeChannelName = null;
-let cmdLog = [];  // shell history for Raw tab
-
-document.querySelectorAll('.page-tab').forEach(btn => {
-  btn.addEventListener('click', () => {
-    document.querySelectorAll('.page-tab').forEach(b => b.classList.remove('active'));
-    btn.classList.add('active');
-    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
-    const page = document.getElementById('page-' + btn.dataset.page);
-    if (page) page.classList.add('active');
-  });
-});
-
-function setStatus(msg, loading) {
-  const el = document.getElementById('status-bar');
-  el.textContent = msg;
-  el.classList.toggle('loading', !!loading);
-}
-
-async function api(method, path, body) {
-  const opts = { method, headers: { 'Content-Type': 'application/json' } };
-  if (body !== undefined) opts.body = JSON.stringify(body);
-  const r = await fetch(path, opts);
-  const data = await r.json();
-  if (!r.ok) throw new Error(data.detail || `HTTP ${r.status}`);
-  return data;
-}
-
-// ══════════════════════════════════════════════════════════
-//  Shell exec — all commands go through /api/pchat/exec
-// ══════════════════════════════════════════════════════════
-
-async function shellExec(cmd, log = true) {
-  const user = getUsername();
-  const res = await api('POST', '/api/pchat/exec', { cmd, user, log });
-  cmdLog.push({ cmd, user, result: res, ts: new Date().toISOString() });
-  return res;
-}
-
-// ══════════════════════════════════════════════════════════
-//  Channels
-// ══════════════════════════════════════════════════════════
-
-async function createChannel() {
-  const input = document.getElementById('new-ch-input');
-  const name = input.value.trim();
-  if (!name) return;
-  input.value = '';
-  setStatus('Creating channel...', true);
-  try {
-    // Navigate to pchat/channels first, then create
-    await shellExec('/select pchat');
-    const mkRes = await shellExec('/select channels');
-    if (mkRes.error) {
-      // channels dir might not exist, create it
-      await shellExec('/mk channels channels');
-      await shellExec('/select channels');
-    }
-    await shellExec(`/mk channel ${name}`);
-    // Go back to pchat for consistent state
-    await shellExec('/up');
-    await shellExec('/up');
-    await loadChannels();
-    selectChannel(name);
-    setStatus('Ready');
-  } catch (e) { setStatus('Error: ' + e.message); }
-}
-
-async function loadChannels() {
-  try {
-    // Navigate to channels dir and list (read-only, no log)
-    await shellExec('/select pchat', false);
-    const selRes = await shellExec('/select channels', false);
-    if (selRes.error) {
-      await shellExec('/up', false);
-      renderChannelList([]);
-      return;
-    }
-    const ls = await shellExec('/ls', false);
-    await shellExec('/up', false);
-    await shellExec('/up', false);
-    renderChannelList(ls.children || []);
-  } catch (e) {
-    renderChannelList([]);
-  }
-}
-
-function renderChannelList(channels) {
-  const el = document.getElementById('channel-list');
-  if (!channels.length) { el.innerHTML = '<div class="chat-empty" style="font-size:10px">No channels</div>'; return; }
-  el.innerHTML = channels.map(ch => {
-    const name = ch.meta?.name || ch.name;
-    const active = name === activeChannelName ? ' active' : '';
-    return `<div class="channel-item${active}" onclick="selectChannel('${esc(name)}')"><span class="ch-hash">#</span> ${esc(name)}</div>`;
-  }).join('');
-}
-
-async function selectChannel(name) {
-  activeChannelName = name;
-  activeChannelPath = `pchat/channels/${name}`;
-  document.getElementById('channel-label').innerHTML = '# <strong>' + esc(name) + '</strong>';
-  await loadMessages();
-  // Re-render channel list to highlight active
-  await loadChannels();
-}
-
-// ══════════════════════════════════════════════════════════
-//  Messages
-// ══════════════════════════════════════════════════════════
-
-function getUsername() {
-  return document.getElementById('username-input').value.trim() || 'anon';
-}
-
-async function sendMessage() {
-  const input = document.getElementById('chat-input');
-  const msg = input.value.trim();
-  if (!msg) return;
-  if (!activeChannelName) {
-    // Auto-create general channel
-    document.getElementById('new-ch-input').value = 'general';
-    await createChannel();
-  }
-  input.value = '';
-  setStatus('Posting...', true);
-  try {
-    // Navigate to channel, post, come back
-    await shellExec('/select pchat');
-    await shellExec('/select channels');
-    await shellExec(`/select ${activeChannelName}`);
-    await shellExec(`/post ${msg}`);
-    // Get updated message list
-    const ls = await shellExec('/ls --sort=date');
-    await shellExec('/up');
-    await shellExec('/up');
-    await shellExec('/up');
-    renderMessages(ls.children || []);
-    setStatus('Ready');
-  } catch (e) {
-    setStatus('Error: ' + e.message);
-  }
-}
-
-async function loadMessages() {
-  if (!activeChannelName) return;
-  try {
-    await shellExec('/select pchat', false);
-    await shellExec('/select channels', false);
-    await shellExec(`/select ${activeChannelName}`, false);
-    const ls = await shellExec('/ls --sort=date', false);
-    await shellExec('/up', false);
-    await shellExec('/up', false);
-    await shellExec('/up', false);
-    renderMessages(ls.children || []);
-  } catch (e) {
-    renderMessages([]);
-  }
-}
-
-function renderMessages(items) {
-  const el = document.getElementById('chat-thread');
-  const msgs = items.filter(i => i.meta?.type === 'message');
-  if (!msgs.length) {
-    el.innerHTML = '<div class="chat-empty">No messages yet. Say something!</div>';
-    return;
-  }
-  const currentUser = getUsername();
-  el.innerHTML = msgs.map(m => {
-    const meta = m.meta || {};
-    const user = meta.user || 'anon';
-    const ts = meta.ts ? new Date(meta.ts).toLocaleTimeString() : '';
-    const content = m.data?.content || m.name || '';
-    const isSelf = user === currentUser;
-    return `<div class="chat-msg${isSelf ? ' self' : ''}">
-      <div class="msg-hdr"><span class="msg-user">${esc(user)}</span><span class="msg-ts">${esc(ts)}</span></div>
-      <div class="msg-content">${esc(content)}</div>
-    </div>`;
-  }).join('');
-  el.scrollTop = el.scrollHeight;
-}
-
-// ══════════════════════════════════════════════════════════
-//  Shell interactive tab
-// ══════════════════════════════════════════════════════════
-
-async function runShell() {
-  const input = document.getElementById('shell-input');
-  const cmd = input.value.trim();
-  if (!cmd) return;
-  input.value = '';
-  const outputEl = document.getElementById('shell-output');
-  outputEl.innerHTML += `<div class="sh-line"><span class="sh-cmd">$ ${esc(cmd)}</span></div>`;
-  try {
-    const res = await shellExec(cmd);
-    const cls = res.error ? 'sh-error' : 'sh-result';
-    outputEl.innerHTML += `<div class="sh-line"><span class="${cls}">${esc(JSON.stringify(res, null, 2))}</span></div>`;
-  } catch (e) {
-    outputEl.innerHTML += `<div class="sh-line"><span class="sh-error">${esc(e.message)}</span></div>`;
-  }
-  outputEl.scrollTop = outputEl.scrollHeight;
-  renderRaw();
-}
-
-// ══════════════════════════════════════════════════════════
-//  FS view tab
-// ══════════════════════════════════════════════════════════
-
-async function renderFsView() {
-  const el = document.getElementById('fs-view');
-  try {
-    const res = await api('GET', '/api/pchat/state');
-    const children = res.children || [];
-    if (!children.length) {
-      el.innerHTML = '<div class="chat-empty" style="padding:12px">Empty workspace</div>';
-      return;
-    }
-    el.innerHTML = children.map(c => {
-      const meta = c.meta || {};
-      return `<div class="pnode">
-        <div class="pnode-hdr" onclick="this.nextElementSibling.classList.toggle('open')">
-          <span class="pnode-id">${esc(c.path)}</span>
-          <span class="pnode-kind">${esc(meta.type || '?')}</span>
-        </div>
-        <div class="pnode-body"><pre>${esc(JSON.stringify(c, null, 2))}</pre></div>
-      </div>`;
-    }).join('');
-  } catch (e) {
-    el.innerHTML = `<div class="chat-empty">${esc(e.message)}</div>`;
-  }
-}
-
-// ══════════════════════════════════════════════════════════
-//  Raw tab + Reset
-// ══════════════════════════════════════════════════════════
-
-function renderRaw() {
-  const el = document.getElementById('raw-view');
-  if (!cmdLog.length) { el.textContent = 'No commands yet'; el.className = 'empty'; return; }
-  el.textContent = JSON.stringify(cmdLog, null, 2);
-  el.className = '';
-}
-
-async function resetAll() {
-  await shellExec('/reset');
-  cmdLog = [];
-  activeChannelPath = null;
-  activeChannelName = null;
-  document.getElementById('channel-label').textContent = 'Select or create a channel';
-  document.getElementById('chat-thread').innerHTML = '<div class="chat-empty">No channel selected</div>';
-  renderChannelList([]);
-  renderRaw();
-  setStatus('Reset — Ready');
-}
-
-// ══════════════════════════════════════════════════════════
-//  Init
-// ══════════════════════════════════════════════════════════
-
-// Username persistence
-const _usernameInput = document.getElementById('username-input');
-_usernameInput.value = localStorage.getItem('pchat_user') || '';
-_usernameInput.addEventListener('input', () => localStorage.setItem('pchat_user', _usernameInput.value));
-
-// Tab switch hooks
-document.querySelectorAll('.page-tab').forEach(btn => {
-  btn.addEventListener('click', () => {
-    if (btn.dataset.page === 'fs') renderFsView();
-  });
-});
-
-loadChannels().then(() => setStatus('Ready'));
-</script>
-</body>
-</html>
