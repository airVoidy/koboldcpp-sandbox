-function renderLayoutPreview() {
-  const el = document.getElementById('layout-preview-body');
-  if (!el) return;
-  if (!_ceSelected) { el.innerHTML = '<div style="color:var(--text-dim);font-size:9px;">Select a component</div>'; return; }
-  // Reuse sample JSON from component editor or generate
-  if (!_layoutSampleJson) _layoutSampleJson = _generateSampleJson(_ceSelected);
-  const existing = document.getElementById('layout-sample-json');
-  if (!existing || el.dataset.ceComp !== _ceSelected) {
-    el.dataset.ceComp = _ceSelected;
-    el.innerHTML = `<div style="font-size:9px;color:var(--text-dim);margin-bottom:4px;">Sample data:</div>`
-      + `<textarea id="layout-sample-json" class="ve-mapping" rows="6" spellcheck="false" style="margin-bottom:6px;font-size:9px;">${esc(_layoutSampleJson)}</textarea>`
-      + `<div id="layout-render-output"></div>`;
-    document.getElementById('layout-sample-json')?.addEventListener('input', (e) => {
-      _layoutSampleJson = e.target.value;
-      _updateLayoutPreview();
-    });
-  }
-  _updateLayoutPreview();
-}
