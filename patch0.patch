-                matching = [j for jid, j in self._jobs.items() if jid.startswith(prefix + ".")]
-                if not matching or not all(j.status == JobStatus.DONE for j in matching):
-                    return False
-            else:
-                job = self._jobs.get(pattern)
-                if not job or job.status != JobStatus.DONE:
-                    return False
-        return True
