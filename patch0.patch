-// ── Reassemble slots (called when node.data changes) ──
-function reassembleNode(nd) {
-  const viewName = nd._view || 'job';
-  const tplName = (_views[viewName]?.template) || viewName;
-  nd.slots = assembleSlots(nd, tplName, viewName);
-}
