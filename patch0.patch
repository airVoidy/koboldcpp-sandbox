-// ══════════════════════════════════════════════════════════
-//  LAYOUT EDITOR — skeleton builder from JSON Schema
-// ══════════════════════════════════════════════════════════
-let _layoutEditorTab = 'components';
-const _layouts = {}; // name → { rows: [{cells: [fieldName]}] }
-let _layoutSampleJson = '';
-
-function _generateLayout(compName) {
-  const tpl = V3C.template(compName);
-  const props = Object.keys(tpl);
-  return { rows: props.map(f => ({ cells: [f] })) };
-}
-
-function _getLayout(compName) {
-  if (!compName) return { rows: [] };
-  // Custom components may store layout
-  if (_customComponents[compName]?.layout) return _customComponents[compName].layout;
-  if (!_layouts[compName]) _layouts[compName] = _generateLayout(compName);
-  return _layouts[compName];
-}
-
-function _saveLayout(compName, layout) {
-  _layouts[compName] = layout;
-  if (_customComponents[compName]) {
-    _customComponents[compName].layout = layout;
-    _saveCustomComponents();
-  }
-}
-
-function _renderSkeletonValue(val) {
-  if (val === undefined || val === null) return '<span style="color:var(--text-dim);font-style:italic;">(empty)</span>';
-  if (typeof val === 'boolean') return `<span style="color:var(--${val ? 'green' : 'red'});">${val}</span>`;
-  if (typeof val === 'number') return `<span style="color:var(--accent3);">${val}</span>`;
-  if (typeof val === 'string') return val ? esc(val.length > 80 ? val.slice(0, 77) + '...' : val) : '<span style="color:var(--text-dim);">""</span>';
-  if (Array.isArray(val)) return `<span style="color:var(--text-dim);">[${val.length}]</span>`;
-  if (typeof val === 'object') return `<span style="color:var(--text-dim);">{${Object.keys(val).join(', ')}}</span>`;
-  return esc(String(val));
-}
-
-function switchEditorTab(tab) {
-  _layoutEditorTab = tab;
-  document.querySelectorAll('[data-editor-tab]').forEach(b => b.classList.toggle('active', b.dataset.editorTab === tab));
-  document.getElementById('editor-sub-components').style.display = tab === 'components' ? 'flex' : 'none';
-  document.getElementById('editor-sub-layout').style.display = tab === 'layout' ? 'flex' : 'none';
-  if (tab === 'layout') renderLayoutPanels();
-}
-
-function renderLayoutPanels() {
-  renderLayoutCells();
-  renderLayoutSkeleton();
-  renderLayoutPreview();
-}
-
-function renderLayoutCells() {
-  const el = document.getElementById('layout-cells-body');
-  if (!el) return;
-  if (!_ceSelected) { el.innerHTML = '<div style="color:var(--text-dim);font-size:9px;">Select a component in Components tab first</div>'; return; }
-  const tpl = V3C.template(_ceSelected);
-  let h = `<div style="font-size:10px;color:var(--accent);font-weight:600;margin-bottom:4px;">${esc(_ceSelected)}</div>`;
-  for (const [fname, v] of Object.entries(tpl)) {
-    const typeStr = Array.isArray(v) ? 'array' : typeof v === 'object' ? 'object' : String(v);
-    h += `<div style="font-size:9px;padding:2px 4px;margin:1px 0;cursor:pointer;border-radius:2px;" data-layout-cell="${esc(fname)}">`;
-    h += `<span style="color:var(--accent2);">${esc(fname)}</span> `;
-    h += `<span style="color:var(--text-dim);font-size:8px;">${esc(typeStr)}</span>`;
-    h += `</div>`;
-  }
-  h += `<button class="btn sm" id="layout-add-extra" style="margin-top:6px;font-size:9px;width:100%;">+ Element</button>`;
-  el.innerHTML = h;
-  // Wire
-  el.querySelectorAll('[data-layout-cell]').forEach(row => {
-    row.addEventListener('click', () => {
-      el.querySelectorAll('[data-layout-cell]').forEach(r => r.style.background = '');
-      row.style.background = 'var(--surface2)';
-      // Highlight in skeleton
-      document.querySelectorAll('.skel-table td').forEach(td => td.classList.remove('skel-highlight'));
-      const td = document.querySelector(`.skel-table td[data-field="${row.dataset.layoutCell}"]`);
-      if (td) td.classList.add('skel-highlight');
-    });
-  });
-  document.getElementById('layout-add-extra')?.addEventListener('click', function() {
-    _inlinePrompt(this, 'element', (name) => {
-    const layout = _getLayout(_ceSelected);
-    layout.rows.push({ cells: [name] });
-    _saveLayout(_ceSelected, layout);
-    renderLayoutPanels();
-    });
-  });
-}
-
-function renderLayoutSkeleton() {
-  const el = document.getElementById('layout-skeleton-body');
-  if (!el) return;
-  if (!_ceSelected) { el.innerHTML = '<div style="color:var(--text-dim);font-size:9px;">Select a component</div>'; return; }
-  const layout = _getLayout(_ceSelected);
-  const tpl = V3C.template(_ceSelected);
-  let h = '';
-  for (let ri = 0; ri < layout.rows.length; ri++) {
-    const row = layout.rows[ri];
-    h += `<div class="skel-row-controls">`;
-    h += `<span style="color:var(--text-dim);font-size:8px;min-width:16px;">${ri + 1}</span>`;
-    if (ri > 0) h += `<span style="cursor:pointer;font-size:9px;color:var(--text-dim);" data-layout-row-up="${ri}">\u2191</span>`;
-    if (ri < layout.rows.length - 1) h += `<span style="cursor:pointer;font-size:9px;color:var(--text-dim);" data-layout-row-down="${ri}">\u2193</span>`;
-    h += `<span style="cursor:pointer;font-size:9px;color:var(--red);margin-left:auto;" data-layout-row-del="${ri}">\u00d7</span>`;
-    h += `</div>`;
-    h += `<table class="skel-table"><tr>`;
-    for (let ci = 0; ci < row.cells.length; ci++) {
-      const field = row.cells[ci];
-      const typeStr = tpl[field] ? (Array.isArray(tpl[field]) ? '[]' : typeof tpl[field] === 'object' ? '{}' : '') : '';
-      h += `<td data-field="${esc(field)}">`;
-      h += `<div class="skel-label">${esc(field)}${typeStr ? ' <span style="color:var(--text-dim);font-size:7px;">' + typeStr + '</span>' : ''}</div>`;
-      h += `<div class="skel-value" style="color:var(--text-dim);font-style:italic;">(data)</div>`;
-      h += `</td>`;
-    }
-    // Button to add cell to this row
-    h += `<td style="border:1px dashed var(--border);cursor:pointer;text-align:center;color:var(--text-dim);font-size:9px;width:20px;" data-layout-add-cell="${ri}">+</td>`;
-    h += `</tr></table>`;
-  }
-  h += `<button class="btn sm" id="layout-add-row" style="margin-top:4px;font-size:9px;">+ Row</button>`;
-  el.innerHTML = h;
-  // Wire
-  el.querySelectorAll('[data-layout-row-up]').forEach(btn => {
-    btn.addEventListener('click', () => {
-      const i = +btn.dataset.layoutRowUp;
-      const rows = layout.rows;
-      [rows[i - 1], rows[i]] = [rows[i], rows[i - 1]];
-      _saveLayout(_ceSelected, layout); renderLayoutPanels();
-    });
-  });
-  el.querySelectorAll('[data-layout-row-down]').forEach(btn => {
-    btn.addEventListener('click', () => {
-      const i = +btn.dataset.layoutRowDown;
-      const rows = layout.rows;
-      [rows[i], rows[i + 1]] = [rows[i + 1], rows[i]];
-      _saveLayout(_ceSelected, layout); renderLayoutPanels();
-    });
-  });
-  el.querySelectorAll('[data-layout-row-del]').forEach(btn => {
-    btn.addEventListener('click', () => {
-      layout.rows.splice(+btn.dataset.layoutRowDel, 1);
-      _saveLayout(_ceSelected, layout); renderLayoutPanels();
-    });
-  });
-  el.querySelectorAll('[data-layout-add-cell]').forEach(td => {
-    td.addEventListener('click', function() {
-      _inlinePrompt(this, 'field', (name) => {
-      layout.rows[+td.dataset.layoutAddCell].cells.push(name);
-      _saveLayout(_ceSelected, layout); renderLayoutPanels();
-      });
-    });
-  });
-  document.getElementById('layout-add-row')?.addEventListener('click', function() {
-    _inlinePrompt(this, 'field', (name) => {
-    layout.rows.push({ cells: [name] });
-    _saveLayout(_ceSelected, layout); renderLayoutPanels();
-    });
-  });
-}
