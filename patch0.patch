-  h += `<div style="font-size:8px;color:var(--text-dim);margin-bottom:2px;">Fields the component declares</div>`;
-  h += `<pre style="font-size:8px;background:var(--surface);border:1px solid var(--border);border-radius:3px;padding:4px;white-space:pre-wrap;max-height:200px;overflow-y:auto;">${esc(JSON.stringify(tpl, null, 2))}</pre>`;
-  // Client Schema — derived from layout cells
-  const layout = _getLayout(_ceSelected);
-  const clientTpl = {};
-  for (const row of layout.rows) {
-    for (const field of row.cells) {
-      clientTpl[field] = tpl[field] || 'string';
-    }
-  }
-  h += `<div style="color:var(--green);font-weight:600;margin:8px 0 4px;">Client Schema</div>`;
-  h += `<div style="font-size:8px;color:var(--text-dim);margin-bottom:2px;">Fields the UI consumes (assembly output)</div>`;
-  h += `<pre style="font-size:8px;background:var(--surface);border:1px solid var(--border);border-radius:3px;padding:4px;white-space:pre-wrap;max-height:200px;overflow-y:auto;">${esc(JSON.stringify(clientTpl, null, 2))}</pre>`;
-  // Extra elements not in component template
-  const extraFields = layout.rows.flatMap(r => r.cells).filter(f => !(f in tpl));
-  if (extraFields.length) {
-    h += `<div style="color:var(--orange);font-weight:600;margin:8px 0 4px;">Extra UI Elements</div>`;
-    h += `<div style="font-size:9px;">${extraFields.map(f => `<span style="color:var(--orange);">${esc(f)}</span>`).join(', ')}</div>`;
-    h += `<div style="font-size:8px;color:var(--text-dim);">Not in component template \u2014 user-added</div>`;
-  }
-  el.innerHTML = h;
-}
