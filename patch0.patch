-    renderState(status);
-    updateCardsFromState(status);
-
-    // Check if all done
-    const allJobs = Object.values(status.jobs || {});
-    const allDone = allJobs.length > 0 && allJobs.every(j => j.status === 'done' || j.status === 'failed' || j.status === 'cancelled');
-    if (allDone) {
-      clearInterval(_pollTimer);
-      _pollTimer = null;
-      document.getElementById('statusDot').style.background = 'var(--green)';
-      document.getElementById('statusText').textContent = 'done';
-    }
-  } catch(_) {}
