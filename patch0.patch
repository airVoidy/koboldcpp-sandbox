-const replay = [];
-let _ctx = null; // currently selected panel name
-
-function exec(cmdStr, silent) {
-  const raw = typeof cmdStr === 'string' ? cmdStr.trim() : '';
-  if (!raw) return;
-
-  // Multi-line: split and handle block commands (action ... end)
-  const lines = raw.split('\n').map(l => l.trim()).filter(l => l && !l.startsWith(';'));
-  let i = 0;
-  while (i < lines.length) {
-    const line = lines[i];
-    const tokens = asmTokenize(line);
-
-    // Block command: "action <name>" ... "end"
-    if (tokens[0] === 'action' && tokens.length >= 2 && !line.includes('{')) {
-      const name = tokens[1];
-      const bodyLines = [];
-      i++;
-      while (i < lines.length && lines[i] !== 'end') { bodyLines.push(lines[i]); i++; }
-      if (i < lines.length) i++; // skip 'end'
-      const asm = bodyLines.join('\n');
-      const fullRaw = `action ${name}\n${bodyLines.join('\n')}\nend`;
-      const cmd = { cmd:'action', name, asm, _ctx: _ctx || 'screen' };
-      if (!['get','ls','find'].includes(cmd.cmd)) {
-        replay.push({ _raw: fullRaw, ...cmd, _ts: Date.now() });
-        applyCommand(cmd);
-      }
-      continue;
-    }
-
-    // Block command: "asm" ... "end"
-    if (tokens[0] === 'asm' && tokens.length === 1) {
-      const bodyLines = [];
-      i++;
-      while (i < lines.length && lines[i] !== 'end') { bodyLines.push(lines[i]); i++; }
-      if (i < lines.length) i++;
-      const code = bodyLines.join('\n');
-      const fullRaw = `asm\n${bodyLines.join('\n')}\nend`;
-      const cmd = { cmd:'asm', code, _ctx: _ctx || 'screen' };
-      replay.push({ _raw: fullRaw, ...cmd, _ts: Date.now() });
-      execAsm(code);
-      continue;
-    }
-
-    // Single-line command
-    const cmd = parseCmd(line);
-    if (!cmd) { i++; continue; }
-    if (['get','ls','find'].includes(cmd.cmd)) { runIntrospect(cmd); i++; continue; }
-    replay.push({ _raw: line, ...cmd, _ts: Date.now() });
-    applyCommand(cmd);
-    i++;
-  }
-  if (!silent) { draw(); updateReplayView(); }
-}
