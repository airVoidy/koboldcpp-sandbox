-                            for img in out["images"]:
-                                fname = img.get("filename", "")
-                                subfolder = img.get("subfolder", "")
-                                img_type = img.get("type", "output")
-                                image_url = f"{server}/view?filename={fname}&subfolder={subfolder}&type={img_type}"
-                                break
-                        if image_url:
-                            break
-                    break
-            except Exception:
-                pass
-
-        if not image_url:
