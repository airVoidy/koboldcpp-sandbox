-  h += `<div style="color:var(--accent2);font-weight:600;margin:6px 0 4px;">COMPONENTS</div>`;
-  h += `<div style="color:var(--text-dim);">${V3C.list().join(', ')}</div>`;
-
-  el.innerHTML = h;
