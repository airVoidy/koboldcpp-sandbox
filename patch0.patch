+// ── Fetch ───────────────────────────────────────────
+async function load() {
+  const params = new URLSearchParams();
+  if (selectedId) params.set('selected_id', selectedId);
+  if (focusId) params.set('focus_id', focusId);
+  const res = await fetch(`${API}/state?${params}`);
+  S = await res.json();
+  if (!selectedId && S.selected_id) selectedId = S.selected_id;
+  if (!focusId && S.focus_id) focusId = S.focus_id;
+  render();
+}
+
+async function serverAction(endpoint, body) {
+  const res = await fetch(`${API}/${endpoint}`, {
+    method: 'POST',
+    headers: { 'Content-Type': 'application/json' },
+    body: JSON.stringify(body)
+  });
+  S = await res.json();
+  if (S.selected_id) selectedId = S.selected_id;
+  setStatus(S.message || (S.ok ? 'ok' : 'error'), !S.ok);
+  render();
+}
+
+async function runCommand(cmd) {
+  await serverAction('command', { command: cmd, selected_id: selectedId, focus_id: focusId });
+}
+
+// ── Render ──────────────────────────────────────────
+function render() {
+  if (!S) return;
+  renderScreen();
+  renderOverlay();
+  renderTree();
+  renderProps();
+  document.getElementById('screen-info').textContent = `${S.screen.cols}×${S.screen.rows}`;
+  document.getElementById('sel-info').textContent = selectedId ? `sel: ${selectedId}` : '';
+}
+
+function renderScreen() {
+  const el = document.getElementById('screen');
+  el.textContent = (S.render.lines || []).join('\n');
+}
+
+function renderOverlay() {
+  const ov = document.getElementById('overlay');
+  ov.innerHTML = '';
+  if (!S.tree) return;
+  for (const n of S.tree) {
+    const [x, y, w, h] = n.rect;
+    const div = document.createElement('div');
+    div.className = 'aabb-ov' + (n.id === selectedId ? ' sel' : '');
+    div.style.left = (x * CW) + 'px';
+    div.style.top = (y * CH) + 'px';
+    div.style.width = (w * CW) + 'px';
+    div.style.height = (h * CH) + 'px';
+    div.dataset.id = n.id;
+    ov.appendChild(div);
+  }
+}
+
+function renderTree() {
+  const el = document.getElementById('tree');
+  let h = '<div class="th">AABB Tree</div>';
+  if (S.tree) {
+    for (const n of S.tree) {
+      const indent = '\u00a0'.repeat(n.depth * 2);
+      const isSel = n.id === selectedId;
+      h += `<div class="tn${isSel ? ' sel' : ''}" data-id="${n.id}">`;
+      h += `${indent}<span class="nm">${n.name || n.id}</span>`;
+      if (n.alias) h += `<span class="al">.${n.alias}</span>`;
+      h += `<span class="rc"> [${n.rect.join(',')}]</span>`;
+      h += `</div>`;
+    }
+  }
+  el.innerHTML = h;
+  el.querySelectorAll('.tn').forEach(tn => {
+    tn.addEventListener('click', () => {
+      selectedId = tn.dataset.id;
+      load();
+    });
+  });
 }
 
