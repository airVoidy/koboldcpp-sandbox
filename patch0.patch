-
-
-@dataclass
-class GatewayJob:
-    id: str
-    worker: str
-    payload: Any
-    priority: Literal["high", "normal", "low"] = "normal"
-    timeout: float = 120.0
-    retry: int = 0
-    status: JobStatus = JobStatus.PENDING
-    result: Any = None
-    error: str | None = None
-    started_at: float | None = None
-    finished_at: float | None = None
-    # LLM params
-    messages: list[dict] | None = None
-    mode: str = "prompt"
-    temp: float = 0.6
-    max_tokens: int = 2048
-    grammar: str | None = None
-    capture: Any = None
-    coerce: str | None = None
