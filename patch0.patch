-// ══════════════════════════════════════════════════════════
-//  ASSEMBLE SLOTS — data layer: Node → Slot[]
-//  Runs assembler per slot, auto-generates type.N ids
-// ══════════════════════════════════════════════════════════
-function assembleSlots(node, templateName, viewName) {
-  const tmpl = _cardTemplates[templateName];
-  if (!tmpl) return [];
-  const view = _views[viewName];
-  const overrides = view?.overrides || {};
-  const typeCounts = {};
-  return tmpl.slots.map(slotDef => {
-    const n = (typeCounts[slotDef.type] = (typeCounts[slotDef.type] || 0) + 1);
-    const id = slotDef.type + '.' + n;
-    const component = slotDef.component || undefined;
-    // Override assembler (fn) takes priority, then slot.asm (DSL text), then slot.assemble (legacy fn)
-    const overrideFn = overrides[id];
-    let data = {};
-    try {
-      if (overrideFn) {
-        data = overrideFn(node) || {};
-      } else if (slotDef.asm) {
-        const state = execAsm(slotDef.asm, { n: node });
-        // Extract all non-internal keys from state as slot data
-        for (const [k, v] of Object.entries(state)) { if (k !== 'n' && k !== 'each_idx') data[k] = v; }
-      } else if (slotDef.assemble) {
-        data = slotDef.assemble(node) || {};
-      }
-    } catch (e) { /* silent */ }
-    return { type: slotDef.type, component, id, data };
-  });
-}
