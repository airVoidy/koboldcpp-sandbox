-async function execAsm(code, extraState) {
-  const state = { ...extraState };
-  const lines = code.split('\n');
-  // Pre-scan labels: :name → line index
-  const labels = {};
-  for (let i = 0; i < lines.length; i++) {
-    const l = lines[i].trim();
-    if (l.startsWith(':')) labels[l] = i;
-  }
-  let ip = 0;
-  const max = lines.length * 50;
-  let steps = 0;
-  while (ip < lines.length && steps < max) {
-    steps++;
-    const line = lines[ip].trim();
-    if (!line || line.startsWith(';') || line.startsWith(':')) { ip++; continue; }
-    const tokens = asmTokenize(line);
-    if (!tokens.length) { ip++; continue; }
-    const op = tokens[0];
-
-    if (op === 'MOV') {
-      asmStore(state, tokens[1], asmResolve(tokens[2], state));
-      ip++;
-    } else if (op === 'CALL') {
-      const dst = tokens[1], fn = tokens[2], args = tokens.slice(3).map(t => asmResolve(t, state));
-      const b = _builtins[fn];
-      if (b) { let r = b(args); if (r instanceof Promise) r = await r; if (dst !== '_') asmStore(state, dst, r); }
-      ip++;
-    } else if (op === 'EACH') {
-      const itemRef = tokens[1], list = asmResolve(tokens[2], state), bodyLen = asmResolve(tokens[3], state);
-      if (Array.isArray(list) && bodyLen > 0) {
-        const bodyLines = lines.slice(ip + 1, ip + 1 + bodyLen);
-        for (let idx = 0; idx < list.length; idx++) {
-          asmStore(state, itemRef, list[idx]);
-          state['each_idx'] = idx;
-          await execAsm(bodyLines.join('\n'), state);
-          list[idx] = asmResolve(itemRef, state);
-        }
-      }
-      ip += 1 + (bodyLen || 0);
-    } else if (op === 'CMP') {
-      const cmpOp = tokens[2], a = asmResolve(tokens[3], state), b = asmResolve(tokens[4], state);
-      let r = false;
-      if (cmpOp === 'eq') r = a == b; else if (cmpOp === 'ne') r = a != b;
-      else if (cmpOp === 'gt') r = a > b; else if (cmpOp === 'lt') r = a < b;
-      asmStore(state, tokens[1], r);
-      ip++;
-    } else if (op === 'JIF') {
-      const cond = asmResolve(tokens[1], state);
-      const target = tokens[2];
-      if (cond) {
-        if (target.startsWith(':') && labels[target] !== undefined) {
-          ip = labels[target]; // jump to label line (will be skipped as :label on next iter)
-        } else {
-          ip += (typeof asmResolve(target, state) === 'number' ? asmResolve(target, state) : 1);
-        }
-      } else { ip++; }
-    } else { ip++; }
-  }
-  return state;
-}
