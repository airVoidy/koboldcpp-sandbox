-document.addEventListener('keydown', (e) => {
-  if(!focusedZone||focusedZone.type!=='input'||activeTab!=='preview') return;
-  const z=focusedZone;
-  let val=z._value||'';
-  if(e.key==='Backspace'){if(cursorPos>0){val=val.slice(0,cursorPos-1)+val.slice(cursorPos);cursorPos--;}}
-  else if(e.key==='Delete'){if(cursorPos<val.length)val=val.slice(0,cursorPos)+val.slice(cursorPos+1);}
-  else if(e.key==='ArrowLeft'){if(cursorPos>0)cursorPos--;}
-  else if(e.key==='ArrowRight'){if(cursorPos<val.length)cursorPos++;}
-  else if(e.key==='Home')cursorPos=0;
-  else if(e.key==='End')cursorPos=val.length;
-  else if(e.key==='Enter'){if(z.action){const p=z._panel;if(p){_ctx=p.name;exec(`run ${z.action} ${JSON.stringify(val)}`);}};return;}
