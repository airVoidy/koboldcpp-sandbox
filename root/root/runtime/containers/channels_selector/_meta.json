{
  "id": "channels_selector",
  "kind": "container",
  "state_schema": {
    "selected": "string|null"
  },
  "actions": {
    "select": {
      "state_path": "selected",
      "rebuild_containers": [
        "channels_selector",
        "current_channel",
        "current_channel_messages"
      ]
    },
    "create_channel": {
      "select_new": true,
      "rebuild_containers": [
        "channels_selector",
        "current_channel",
        "current_channel_messages"
      ]
    }
  },
  "resolve": {
    "source_root": "pchat/channels",
    "children": "direct"
  }
}