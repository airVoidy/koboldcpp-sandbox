{
  "id": "current_channel_messages",
  "kind": "table",
  "depends_on": [
    "channels_selector"
  ],
  "selected_from": {
    "container": "channels_selector",
    "state_path": "selected"
  },
  "table": {
    "local_root": "rows",
    "columns": [
      "user",
      "content",
      "ts",
      "reactions",
      "_deleted"
    ],
    "autoload": {
      "op": "load_child_log",
      "source_path_template": "pchat/channels/{containers.channels_selector.state.selected}",
      "projection_root": "item",
      "fields": [
        "_meta.user",
        "_data.content",
        "_meta.ts",
        "_data.reactions",
        "_data._deleted"
      ],
      "replace": true,
      "from_end": true,
      "visible_only": true,
      "limit": 50
    }
  }
}